FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends bash curl ca-certificates python3 python3-reportlab python3-pypdf python3-pil poppler-utils && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY API_tests API_tests
COPY testdata testdata
COPY ci/run_project_api_regression.sh ci/run_project_api_regression.sh
RUN chmod +x ci/run_project_api_regression.sh

ENV BASE_URL=http://ironpage:8080
CMD ["bash", "ci/run_project_api_regression.sh"]
