FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends bash curl python3 ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY ci/api_smoke.sh ci/api_smoke.sh
RUN chmod +x ci/api_smoke.sh

ENV BASE_URL=http://ironpage:8080
CMD ["bash", "ci/api_smoke.sh"]
